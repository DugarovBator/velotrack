# ════════════════════════════════════════════════
#  VeloTrack — .gitignore
#  Исключает системный и редакторский мусор
# ════════════════════════════════════════════════

# ── macOS ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ── Windows ──────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux ────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── Редакторы / IDE ───────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ и т.д.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.tml
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ── Node.js (если добавить тулинг в будущем) ────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Логи ─────────────────────────────────────────
logs/
*.log
*.log.*

# ── Временные файлы ───────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Переменные окружения / секреты ───────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ── Кэш инструментов ─────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache

# ── Артефакты сборки (на случай добавления бандлера) ──
dist/
build/
public/bundle.*
